{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleDetection": "force",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "types": ["chrome"],
    "useDefineForClassFields": false
  },
  "include": [
    "typecheck-smoke.ts",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "__tests__",
    "build.js",
    "quality-gate.js",
    "resize_screenshots.js",
    "debug_sync.js"
  ]
}