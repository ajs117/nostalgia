{
  "name": "nostalgia",
  "version": "2.3.0",
  "description": "nostalgia - Your Instagram saved posts viewer",
  "scripts": {
    "build": "node build.js",
    "package": "npm run build && powershell -ExecutionPolicy Bypass -Command \"Compress-Archive -Path dist\\* -DestinationPath ('nostalgia-v' + $env:npm_package_version + '.zip') -Force\"",
    "resize-screenshots": "node resize_screenshots.js",
    "lint": "eslint \"*.js\" \"**/*.js\" --ignore-pattern \"node_modules/**\" --ignore-pattern \"dist/**\"",
    "lint:fix": "eslint --fix \"*.js\" \"**/*.js\" --ignore-pattern \"node_modules/**\" --ignore-pattern \"dist/**\"",
    "typecheck": "tsc -p tsconfig.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "quality-gate": "node quality-gate.js"
  },
  "keywords": [
    "chrome-extension",
    "instagram",
    "nostalgia"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/chrome": "^0.1.40",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "sharp": "^0.33.5",
    "terser": "^5.44.1",
    "typescript": "^6.0.2"
  }
}
