{
  "name": "nostalgia",
  "version": "1.5.0",
  "description": "nostalgia - Your Instagram saved posts viewer",
  "scripts": {
    "build": "node build.js",
    "package": "node build.js && cd dist && powershell Compress-Archive -Path * -DestinationPath ../nostalgia-v1.5.zip -Force",
    "resize-screenshots": "node resize_screenshots.js",
    "lint": "eslint \"*.js\" \"**/*.js\" --ignore-pattern \"node_modules/**\" --ignore-pattern \"dist/**\"",
    "lint:fix": "eslint --fix \"*.js\" \"**/*.js\" --ignore-pattern \"node_modules/**\" --ignore-pattern \"dist/**\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "quality-gate": "node quality-gate.js"
  },
  "keywords": [
    "chrome-extension",
    "instagram",
    "nostalgia"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "sharp": "^0.33.5",
    "terser": "^5.44.1"
  }
}
