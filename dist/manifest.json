{
   "action": {
      "default_icon": {
         "128": "logo128.png",
         "16": "logo16.png",
         "48": "logo48.png"
      },
      "default_title": "__MSG_actionTitle__"
   },
   "background": {
      "service_worker": "background.js"
   },
   "content_scripts": [
      {
         "js": [
            "syncOrdering.js",
            "contentScript.js"
         ],
         "matches": [
            "https://www.instagram.com/*"
         ]
      }
   ],
   "default_locale": "en",
   "description": "__MSG_appDescription__",
   "host_permissions": [
      "https://*.instagram.com/*",
      "https://i.instagram.com/*",
      "https://*.fbcdn.net/*",
      "https://*.cdninstagram.com/*"
   ],
   "icons": {
      "128": "logo128.png",
      "16": "logo16.png",
      "48": "logo48.png",
      "192": "logo192.png",
      "512": "logo512.png"
   },
   "manifest_version": 3,
   "name": "__MSG_appName__",
   "permissions": [
      "downloads",
      "storage",
      "scripting",
      "tabs"
   ],
   "version": "2.3.5",
   "web_accessible_resources": [
      {
         "matches": [
            "\u003Call_urls>"
         ],
         "resources": [
            "index.html"
         ]
      }
   ]
}