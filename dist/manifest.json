{
   "action": {
      "default_icon": {
         "128": "logo128.png",
         "16": "logo16.png",
         "48": "logo48.png"
      },
      "default_title": "Nostalgia"
   },
   "background": {
      "service_worker": "background.js"
   },
   "content_scripts": [ {
      "js": [ "contentScript.js" ],
      "matches": [ "https://www.instagram.com/*" ]
   } ],
   "description": "Sync and organize your Instagram saved posts offline. All data stored locally.",
   "host_permissions": [ "https://*.instagram.com/*", "https://*.fbcdn.net/*" ],
   "icons": {
      "128": "logo128.png",
      "16": "logo16.png",
      "48": "logo48.png",
      "192": "logo192.png",
      "512": "logo512.png"
   },
   "manifest_version": 3,
   "name": "nostalgia",
   "permissions": [ "storage", "scripting", "tabs" ],
   "version": "1.0",
   "web_accessible_resources": [ {
      "matches": [ "\u003Call_urls>" ],
      "resources": [ "index.html" ]
   } ]
}
